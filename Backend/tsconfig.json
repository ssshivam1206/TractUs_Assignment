{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "generated/**/*.ts"],
  "exclude": ["dist/**/*.ts", "src/**/*.test.ts", "tests/**/*.ts"]
}
